<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <meta name="description" content="Learn about JC Groups - your trusted partner for equipment rentals, construction, and facility services across Canada.">
  <meta name="keywords" content="about JC Groups, equipment rental, construction services, facility management, Canada">
  <title>About JC Groups - Equipment Rental & Construction Services</title>
  <link rel="icon" href="/images/Favicon.png">
  
  <!-- Font Awesome 6 (free, modern, matches the original's icon style) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- External Stylesheets -->
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/about.css">
</head>
<body>

  <%- include('partials/header') %>

  <main>
    <!-- Hero Section -->
    <div class="about-hero">
      <div class="hero-overlay"></div>
      <div class="about-hero-content">
        <div class="hero-badge">ABOUT US</div>
        <h1 class="about-hero-title">Built on Trust. Driven by Service.</h1>
        <p class="about-hero-subtitle">JC Groups — Canada's Partner for Equipment Rentals, Construction & Facility Services</p>
        <div class="hero-cta">
          <a href="#contact" class="hero-btn">Get Started</a>
        </div>
      </div>
    </div>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-number">20+</div>
            <div class="stat-label">Years in Business</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">5K+</div>
            <div class="stat-label">Projects Completed</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">98%</div>
            <div class="stat-label">Client Satisfaction</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">3</div>
            <div class="stat-label">Service Divisions</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Who We Are Section -->
    <section class="about-content-section who-we-are">
      <div class="container">
        <div class="content-row">
          <div class="content-col text-col">
            <div class="section-label">Who We Are</div>
            <h2>A Canadian Company Built on Hard Work</h2>
            <p>JC Groups is a Canadian-owned company with over 20 years of experience delivering equipment rentals, construction services, and facility management solutions. We serve contractors, property managers, municipalities, and businesses of all sizes across Canada.</p>
            <p>From heavy equipment rentals to full-scale construction and maintenance, our three divisions work together to give clients a single, reliable partner for every project phase.</p>
            <ul class="about-list">
              <li><i class="fas fa-check"></i> Equipment Rentals — wide fleet for any job site</li>
              <li><i class="fas fa-check"></i> Construction Services — ground-up builds & renovations</li>
              <li><i class="fas fa-check"></i> Facility Management — maintenance & operations support</li>
            </ul>
          </div>
          <div class="content-col image-col">
            <div class="about-image-box">
              <i class="fas fa-handshake"></i>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Mission & Values Section -->
    <section class="our-mission-section">
      <div class="container">
        <div class="mission-header">
          <div class="section-label">Our Purpose</div>
          <h2>Mission & Core Values</h2>
        </div>

        <div class="mission-cards-grid">
          <div class="mission-item-card">
            <div class="mission-item-icon">
              <i class="fas fa-bullseye"></i>
            </div>
            <h3>Our Mission</h3>
            <p>Deliver dependable equipment and services that help Canadian businesses get the job done — on time, on budget, and to the highest standard.</p>
          </div>

          <div class="mission-item-card">
            <div class="mission-item-icon">
              <i class="fas fa-handshake"></i>
            </div>
            <h3>Integrity First</h3>
            <p>Honest communication, transparent pricing, and a commitment to doing what we say we'll do — every single time.</p>
          </div>

          <div class="mission-item-card">
            <div class="mission-item-icon">
              <i class="fas fa-hard-hat"></i>
            </div>
            <h3>Safety Always</h3>
            <p>Rigorous inspections, maintenance, and strict safety protocols to protect workers, clients, and job sites on every project.</p>
          </div>

          <div class="mission-item-card">
            <div class="mission-item-icon">
              <i class="fas fa-star"></i>
            </div>
            <h3>Excellence</h3>
            <p>Exceeding expectations and delivering outstanding results in every aspect of what we do.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="why-choose-section">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Our Advantages</div>
          <h2>Why Choose JC RENTALS?</h2>
        </div>
        
        <div class="features-grid-redesigned">
          <div class="feature-card-redesigned">
            <div class="feature-icon-container">
              <i class="fas fa-warehouse"></i>
            </div>
            <h3>Large Equipment Fleet</h3>
            <p>Excavators, skid steers, lifts, generators, compactors and more — ready when you need them</p>
            <a href="/equipment" class="feature-link">View Equipment <i class="fas fa-arrow-right"></i></a>
          </div>
          
          <div class="feature-card-redesigned">
            <div class="feature-icon-container">
              <i class="fas fa-hard-hat"></i>
            </div>
            <h3>Construction Services</h3>
            <p>Full-service construction from site prep and excavation to builds and renovations</p>
            <a href="/contact" class="feature-link">Get a Quote <i class="fas fa-arrow-right"></i></a>
          </div>
          
          <div class="feature-card-redesigned">
            <div class="feature-icon-container">
              <i class="fas fa-building"></i>
            </div>
            <h3>Facility Management</h3>
            <p>Ongoing maintenance, operations support, and facility services for commercial properties</p>
            <a href="/contact" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
          </div>
          
          <div class="feature-card-redesigned">
            <div class="feature-icon-container">
              <i class="fas fa-dollar-sign"></i>
            </div>
            <h3>Transparent Pricing</h3>
            <p>No hidden fees — clear, competitive rates with flexible daily, weekly, and monthly options</p>
            <a href="/contact" class="feature-link">Get Quote <i class="fas fa-arrow-right"></i></a>
          </div>
          
          <div class="feature-card-redesigned">
            <div class="feature-icon-container">
              <i class="fas fa-check-circle"></i>
            </div>
            <h3>Certified & Insured</h3>
            <p>Fully licensed, insured, and compliant — giving you peace of mind on every job</p>
            <a href="/about" class="feature-link">Learn More <i class="fas fa-arrow-right"></i></a>
          </div>
          
          <div class="feature-card-redesigned">
            <div class="feature-icon-container">
              <i class="fas fa-truck"></i>
            </div>
            <h3>Delivery & Pickup</h3>
            <p>Reliable on-site delivery and pickup across our service areas to keep your project moving</p>
            <a href="/contact" class="feature-link">Book Delivery <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="testimonials-section">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Testimonials</div>
          <h2>Client Experiences</h2>
        </div>
        
        <div class="testimonials-grid">
          <div class="testimonial-card">
            <div class="stars">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p class="testimonial-text">"From the moment I set foot on the island, I knew I wanted to create something truly special—a getaway where I could escape the hustle and bustle of everyday life. Working with the team to bring my dream cottage to life was an incredible experience."</p>
            <p class="testimonial-author">— Robert &amp; Family, Client</p>
          </div>
          
          <div class="testimonial-card">
            <div class="stars">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p class="testimonial-text">"Despite the challenges of building on a water access island, the team's expertise and dedication made the process smooth and enjoyable. Their attention to detail and commitment to quality ensured that every aspect of my cottage reflected the tranquility of its surroundings."</p>
            <p class="testimonial-author">— Robert &amp; Family, Client</p>
          </div>

          <div class="testimonial-card">
            <div class="stars">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p class="testimonial-text">"Moving into our new home built by JC Contracting has been an absolute dream come true. From the initial planning stages to the final touches, JC Contracting's attention to detail and commitment to quality craftsmanship have been exceptional."</p>
            <p class="testimonial-author">— Rene &amp; George, Client</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action Section -->
    <section class="about-cta-section" id="contact">
      <div class="container">
        <div class="cta-content">
          <h2>Ready to Work with JC Groups?</h2>
          <p>Reach out today — our team is ready to help with rentals, construction, or facility services</p>
          <div class="about-cta-buttons">
            <a href="/equipment" class="cta-btn primary-btn">Browse Equipment</a>
            <a href="tel:18883547368" class="cta-btn secondary-btn">
              <i class="fas fa-phone"></i> Call 1-888-354-7368
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

</body>
</html>
