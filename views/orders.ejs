<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="View and manage your equipment rental orders at JC Rentals.">
  <title>My Orders - JC Rentals</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/profile.css">
  <link rel="stylesheet" href="/css/orders.css">

  <style>
    .order-card {
      transition: all 0.3s ease;
    }

    .order-card.collapsed .order-items,
    .order-card.collapsed .order-footer {
      display: none;
    }

    .order-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      user-select: none;
    }

    .toggle-icon {
      font-size: 18px;
      color: #666;
      transition: transform 0.3s ease;
    }

    .order-card.collapsed .toggle-icon {
      transform: rotate(-90deg);
    }

    .item-image {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border-radius: 4px;
      margin-right: 12px;
    }

    .item {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .item-content {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .item-details {
      flex: 1;
    }

    .item-right {
      display: flex;
      align-items: center;
      gap: 20px;
      white-space: nowrap;
    }

    .item-price {
      font-weight: 600;
      min-width: 80px;
      text-align: right;
    }

    .item-badges {
      display: flex;
      gap: 8px;
    }

    .item-badge {
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .badge-return {
      background: linear-gradient(135deg, #FF9800, #F57C00);
      color: white;
    }
  </style></head>
<body>

  <%- include('partials/header') %>

  <!-- Orders Hero -->
  <section class="orders-hero">
    <div>
      <h1>My Orders</h1>
      <p>Track and Manage Your Rentals</p>
    </div>
  </section>

  <!-- Orders Container -->
  <main class="profile-container">
    <div class="profile-grid">
      <!-- Sidebar Component -->
      <%- include('partials/sidebar', { activeTab: 'orders', sidebarData: { title: 'My Orders', icon: 'fas fa-clipboard-list' } }) %>

      <!-- Main Content -->
      <div class="profile-content">
        <!-- Filter Section -->
        <div class="orders-header">
          <h2>Your Rental Orders</h2>
          <div class="filter-controls">
            <button class="filter-btn active" data-filter="all">All Orders</button>
            <button class="filter-btn" data-filter="active">Active</button>
            <button class="filter-btn" data-filter="completed">Completed</button>
            <button class="filter-btn" data-filter="cancelled">Cancelled</button>
          </div>
        </div>

        <!-- Orders List -->
        <div class="orders-list">
      <% if (orders && orders.length > 0) { %>
        <% orders.forEach((order) => { %>
          <div class="order-card collapsed" data-status="<%= order.status %>">
            <div class="order-header">
              <div style="display: flex; align-items: center; gap: 15px; flex: 1;">
                <i class="fas fa-chevron-down toggle-icon"></i>
                <div class="order-id">
                  <h3>Order #<%= order.orderNumber %></h3>
                  <span class="order-date"><%= new Date(order.createdAt).toLocaleDateString() %></span>
                </div>
              </div>
              <div class="order-status">
                <span class="status-badge status-<%= order.status %>"><%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %></span>
              </div>
            </div>

            <div class="order-items">
              <% if (order.items && order.items.length > 0) { %>
                <% order.items.forEach((item) => { %>
                  <div class="item">
                    <% if (item.equipmentImage) { %>
                      <img src="<%= item.equipmentImage %>" alt="<%= item.equipmentName %>" class="item-image">
                    <% } %>
                    <div class="item-content">
                      <div class="item-details">
                        <p class="item-name"><%= item.equipmentName %></p>
                        <p class="item-quantity">Quantity: <%= item.quantity %></p>
                        <p class="item-dates">
                          <%= new Date(order.rentalPeriod.startDate).toLocaleDateString() %> - 
                          <%= new Date(order.rentalPeriod.endDate).toLocaleDateString() %>
                        </p>
                      </div>
                      <div class="item-right">
                        <div class="item-price">$<%= item.subtotal.toFixed(2) %></div>
                        <div class="item-badges">
                          <% 
                            const now = new Date();
                            const endDate = new Date(order.rentalPeriod.endDate);
                            const isRented = now < endDate;
                          %>
                          <% if (!isRented) { %>
                            <span class="item-badge badge-return">
                              <i class="fas fa-undo"></i> Return
                            </span>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>

            <div class="order-footer">
              <div class="order-total">Total: <strong>$<%= order.totalAmount.toFixed(2) %></strong></div>
              <div class="order-actions">
                <% if (order.status === 'pending') { %>
                  <button class="action-btn view-btn">
                    <i class="fas fa-eye"></i> View Details
                  </button>
                  <button class="action-btn cancel-btn">
                    <i class="fas fa-times"></i> Cancel Order
                  </button>
                <% } else if (order.status === 'active') { %>
                  <button class="action-btn view-btn">
                    <i class="fas fa-eye"></i> View Details
                  </button>
                  <button class="action-btn extend-btn">
                    <i class="fas fa-plus"></i> Extend Rental
                  </button>
                <% } else if (order.status === 'completed') { %>
                  <button class="action-btn view-btn">
                    <i class="fas fa-eye"></i> View Details
                  </button>
                  <button class="action-btn reorder-btn">
                    <i class="fas fa-redo"></i> Rent Again
                  </button>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <!-- Empty State (No orders yet) -->
        <div class="empty-state">
          <i class="fas fa-inbox"></i>
          <h3>No orders yet</h3>
          <p>Start by browsing our equipment catalog and placing your first rental order.</p>
          <a href="/equipment" class="browse-btn">Browse Equipment</a>
        </div>
      <% } %>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Filter button functionality
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        
        const filter = this.dataset.filter;
        document.querySelectorAll('.order-card').forEach(card => {
          if (filter === 'all' || card.dataset.status === filter) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });

    // Collapse/Expand functionality
    document.querySelectorAll('.order-header').forEach(header => {
      header.addEventListener('click', function(e) {
        // Don't toggle if clicking on buttons
        if (e.target.closest('.order-status, .action-btn, button')) {
          return;
        }
        
        const card = this.closest('.order-card');
        card.classList.toggle('collapsed');
      });
    });
  </script>

</body>
</html>
