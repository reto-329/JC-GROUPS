<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Contact JC Rentals for equipment rental inquiries, quotes, and support. Call or fill out our contact form.">
  <title>Contact Us - JC Rentals</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/contact.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="contact-hero">
    <div>
      <h1>Get in Touch</h1>
      <p>We're Ready to Help Your Project</p>
    </div>
  </section>

  <!-- Contact Content -->
  <main class="contact-container">

    <div class="contact-grid">
      <!-- Contact Form -->
      <div class="contact-form">
        <h2>Send us a Message</h2>
        <form id="contactForm" method="POST" action="/contact">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name *</label>
              <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone">
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email" required>
          </div>

          <div class="form-group">
            <label for="equipment">Equipment Type</label>
            <select id="equipment" name="equipment">
              <option value="">Select Equipment...</option>
              <option value="scissor-lifts">Scissor Lifts</option>
              <option value="boom-lifts">Boom Lifts</option>
              <option value="forklifts">Forklifts</option>
              <option value="telehandlers">Telehandlers</option>
              <option value="skid-steer">Skid Steer Loaders</option>
              <option value="excavators">Compact Excavators</option>
              <option value="track-loaders">Track Loaders</option>
              <option value="generators">Generators</option>
              <option value="air-compressors">Air Compressors</option>
              <option value="concrete-equipment">Concrete Equipment</option>
              <option value="other">Other Equipment</option>
              <option value="custom">Custom Request</option>
            </select>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="start-date">Project Start Date</label>
              <input type="date" id="start-date" name="start-date">
            </div>
            <div class="form-group">
              <label for="rental-duration">Rental Duration (Days)</label>
              <input type="number" id="rental-duration" name="rental-duration" min="1" placeholder="e.g., 7">
            </div>
          </div>

          <div class="form-group">
            <label for="details">Project Details & Special Requirements</label>
            <textarea id="details" name="details" placeholder="Tell us about your project and any specific equipment needs..."></textarea>
          </div>

          <div class="form-group">
            <label for="message">Additional Message</label>
            <textarea id="message" name="message" placeholder="Any other questions or comments..."></textarea>
          </div>

          <button type="submit" class="submit-btn">Send Inquiry</button>
        </form>
      </div>

      <!-- Contact Information -->
      <div class="contact-info">
        <div class="contact-info-item">
          <div class="contact-info-icon">
            <i class="fas fa-phone-alt"></i>
          </div>
          <div class="contact-info-content">
            <h3>Phone Support</h3>
            <p><a href="tel:+1-888-354-7368">+1 (888) 354-7368</a></p>
            <p style="margin-top: 0.5rem; font-size: 0.85em; color: #999;">Available during business hours</p>
          </div>
        </div>

        <div class="contact-info-item">
          <div class="contact-info-icon">
            <i class="fas fa-envelope"></i>
          </div>
          <div class="contact-info-content">
            <h3>Email</h3>
            <p><a href="mailto:info@jcrentals.com">info@jcrentals.com</a></p>
            <p style="margin-top: 0.5rem; font-size: 0.85em; color: #999;">We'll respond within 24 hours</p>
          </div>
        </div>

        <div class="contact-info-item">
          <div class="contact-info-icon">
            <i class="fas fa-map-marker-alt"></i>
          </div>
          <div class="contact-info-content">
            <h3>Address</h3>
            <p>123 Main Street<br>Your City, State 12345<br>United States</p>
          </div>
        </div>

        <div class="contact-info-item">
          <div class="contact-info-icon">
            <i class="fas fa-clock"></i>
          </div>
          <div class="contact-info-content">
            <h3>Business Hours</h3>
            <ul class="hours-list">
              <li>
                <span class="day">Monday - Friday</span>
                <span class="time">8:00 AM - 6:00 PM</span>
              </li>
              <li>
                <span class="day">Saturday</span>
                <span class="time">9:00 AM - 4:00 PM</span>
              </li>
              <li>
                <span class="day">Sunday</span>
                <span class="time">Closed</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Services & Benefits -->
    <section class="cta-section-contact">
      <h2>Why Choose JC Rentals?</h2>
      <p>Expert equipment rental with professional service and competitive rates</p>
      <div class="services-grid">
        <div class="service-item">
          <i class="fas fa-check-circle"></i>
          <h3>Expert Support</h3>
          <p>Knowledgeable staff to help you select the right equipment</p>
        </div>
        <div class="service-item">
          <i class="fas fa-truck"></i>
          <h3>Delivery Available</h3>
          <p>Fast and reliable delivery to your job site</p>
        </div>
        <div class="service-item">
          <i class="fas fa-wrench"></i>
          <h3>Well Maintained</h3>
          <p>All equipment fully serviced and in excellent condition</p>
        </div>
        <div class="service-item">
          <i class="fas fa-dollar-sign"></i>
          <h3>Competitive Rates</h3>
          <p>Best prices with flexibility for long-term rentals</p>
        </div>
        <div class="service-item">
          <i class="fas fa-headset"></i>
          <h3>24/7 Available</h3>
          <p>Emergency support for your equipment needs</p>
        </div>
        <div class="service-item">
          <i class="fas fa-star"></i>
          <h3>Trusted Partner</h3>
          <p>Serving contractors and businesses since 2015</p>
        </div>
      </div>
    </section>

  </main>

  <%- include('partials/footer') %>

  <script>
    document.getElementById('contactForm').addEventListener('submit', function(e) {
      e.preventDefault();
      // Form validation
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      
      if (!name || !email) {
        alert('Please fill in all required fields.');
        return;
      }

      // Here you would typically send the form data to your server
      alert('Thank you for your inquiry! We will contact you soon.');
      this.reset();
    });
  </script>

</body>
</html>
