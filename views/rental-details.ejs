<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Rent equipment from JC Rentals">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/rental-details.css">
</head>
<body>

  <%- include('partials/header') %>

  <main
    class="rental-container"
    data-equipment-id="<%= equipment._id %>"
    data-daily-rate="<%= equipment.dailyRate %>"
    data-qty-available="<%= equipment.quantityAvailable %>"
    data-user-id="<%= userId || '' %>"
    data-equipment-name="<%= equipment.name %>"
    data-equipment-image="<%= equipment.image || '' %>"
  >
    <!-- Equipment Details -->
    <div class="rd-details">
      <div class="rd-image">
        <% if (equipment.image) { %>
          <img src="<%= equipment.image %>" alt="<%= equipment.name %>">
        <% } else { %>
          <i class="fas fa-tools"></i>
        <% } %>
      </div>

      <div class="rd-info">
        <h2><%= equipment.name %></h2>
        <p><strong>Category:</strong> <%= equipment.category %></p>
        <p><strong>Description:</strong> <%= equipment.description %></p>
        <p><strong>In Stock:</strong> <%= equipment.quantityAvailable %> / <%= equipment.quantity %></p>
      </div>

      <div class="rd-pricing-box">
        <div class="rd-pricing-option">
          <div class="rd-pricing-label">DAILY</div>
          <div class="rd-pricing-price">$<%= equipment.dailyRate %></div>
        </div>
        <div class="rd-pricing-option">
          <div class="rd-pricing-label">WEEKLY</div>
          <div class="rd-pricing-price">$<%= equipment.weeklyRate || (equipment.dailyRate * 7 * 0.9).toFixed(2) %></div>
        </div>
        <div class="rd-pricing-option">
          <div class="rd-pricing-label">MONTHLY</div>
          <div class="rd-pricing-price">$<%= equipment.monthlyRate || (equipment.dailyRate * 30 * 0.8).toFixed(2) %></div>
        </div>
      </div>
    </div>

    <!-- Rental Form -->
    <div class="rd-form-wrap">
      <form id="rentalForm">
        <!-- Step 1: Postal Code -->
        <div class="rd-step">
          <div class="rd-step-header">
            <div class="rd-step-number">1</div>
            <div class="rd-step-label">Delivery Location</div>
          </div>
          <div class="rd-form-group">
            <label for="postalCode">Postal Code</label>
            <input type="text" id="postalCode" name="postalCode" placeholder="e.g. K0L1W0" maxlength="7" autocomplete="off" required>
            <div id="postalCodeError" class="rd-field-error"></div>
          </div>
        </div>

        <!-- Step 2: Rental Duration -->
        <div class="rd-step">
          <div class="rd-step-header">
            <div class="rd-step-number">2</div>
            <div class="rd-step-label">Rental Duration</div>
          </div>
          <div class="rd-form-group">
            <label for="rentalDays">Number of days</label>
            <div class="rd-input-row">
              <input type="number" id="rentalDays" name="rentalDays" value="1" min="1" required>
              <span class="rd-input-suffix">Day(s)</span>
            </div>
          </div>
        </div>

        <!-- Step 3: Quantity -->
        <div class="rd-step">
          <div class="rd-step-header">
            <div class="rd-step-number">3</div>
            <div class="rd-step-label">Quantity</div>
          </div>
          <div class="rd-form-group">
            <label for="rentalQty">Units to rent</label>
            <div class="rd-qty-control">
              <button type="button" id="decreaseQty">−</button>
              <input type="number" id="rentalQty" name="quantity" value="1" min="1" max="<%= equipment.quantityAvailable %>">
              <button type="button" id="increaseQty">+</button>
            </div>
          </div>
        </div>

        <!-- Step 4: Start Date -->
        <div class="rd-step">
          <div class="rd-step-header">
            <div class="rd-step-number">4</div>
            <div class="rd-step-label">Pickup Date</div>
          </div>
          <div class="rd-form-group">
            <label for="startDate">Start Date</label>
            <input type="date" id="startDate" name="startDate" required>
          </div>
        </div>

        <!-- Step 5: Summary -->
        <div class="rd-step">
          <div class="rd-step-header">
            <div class="rd-step-number">5</div>
            <div class="rd-step-label">Order Summary</div>
          </div>

          <div class="rd-summary">
            <div class="rd-summary-row">
              <span><span id="summaryDays">1</span> day(s) × <span id="summaryQty">1</span> unit(s)</span>
              <span>$<span id="equipmentCost">0.00</span></span>
            </div>
            <div class="rd-summary-row rd-summary-total">
              <span>TOTAL</span>
              <span>$<span id="totalPrice">0.00</span></span>
            </div>
          </div>

          <button type="button" id="completeOrderBtn" class="rd-submit-btn">
            <i class="fas fa-shopping-cart"></i> COMPLETE ORDER
          </button>
        </div>
      </form>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/rental-details.js"></script>

</body>
</html>
