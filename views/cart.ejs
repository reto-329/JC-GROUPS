<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Your Rental Cart - JC Rentals">
  <title>Shopping Cart - JC Rentals</title>
  <link rel="icon" href="/images/Favicon.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <style>
    .cart-container {
      max-width: 1200px;
      margin: 40px auto;
      padding: 20px;
    }

    .cart-header {
      margin-bottom: 30px;
    }

    .cart-header h1 {
      font-size: 32px;
      color: #333;
      margin-bottom: 10px;
    }

    .cart-content {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 30px;
    }

    @media (max-width: 768px) {
      .cart-content {
        grid-template-columns: 1fr;
      }
    }

    .cart-items {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      overflow: hidden;
    }

    .empty-cart {
      padding: 60px 20px;
      text-align: center;
      color: #999;
    }

    .empty-cart i {
      font-size: 60px;
      color: #ddd;
      margin-bottom: 20px;
    }

    .empty-cart p {
      font-size: 18px;
      margin-bottom: 20px;
    }

    .cart-item {
      display: grid;
      grid-template-columns: 100px 1fr 100px 120px;
      gap: 20px;
      align-items: center;
      padding: 20px;
      border-bottom: 1px solid #e0e0e0;
    }

    .cart-item:last-child {
      border-bottom: none;
    }

    @media (max-width: 768px) {
      .cart-item {
        grid-template-columns: 80px 1fr;
        gap: 15px;
      }
    }

    .item-image {
      width: 100px;
      height: 100px;
      background: #f0f0f0;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .item-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .item-details {
      display: flex;
      flex-direction: column;
    }

    .item-name {
      font-size: 16px;
      font-weight: 600;
      color: #333;
      margin-bottom: 5px;
    }

    .item-meta {
      font-size: 13px;
      color: #999;
      margin-bottom: 8px;
    }

    .item-dates {
      font-size: 12px;
      color: #666;
      background: #f9f9f9;
      padding: 5px 8px;
      border-radius: 4px;
      display: inline-block;
      width: fit-content;
    }

    .quantity-control {
      display: flex;
      align-items: center;
      gap: 8px;
      justify-self: center;
    }

    .quantity-control button {
      width: 30px;
      height: 30px;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f0f0f0;
      border: 1px solid #ddd;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.2s;
    }

    .quantity-control button:hover {
      background: #007bff;
      color: white;
      border-color: #007bff;
    }

    .quantity-display {
      width: 40px;
      text-align: center;
      font-weight: 600;
    }

    .item-price {
      text-align: right;
      font-weight: 600;
      color: #007bff;
      font-size: 16px;
    }

    @media (max-width: 768px) {
      .quantity-control,
      .item-price {
        display: none;
      }

      .cart-item {
        position: relative;
      }
    }

    .remove-btn {
      background: none;
      border: none;
      color: #dc3545;
      cursor: pointer;
      font-size: 18px;
      padding: 5px;
      transition: all 0.2s;
    }

    .remove-btn:hover {
      font-size: 20px;
      transform: scale(1.2);
    }

    .cart-sidebar {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .cart-summary {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 25px;
    }

    .summary-title {
      font-size: 18px;
      font-weight: 600;
      color: #333;
      margin-bottom: 20px;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;
      font-size: 14px;
      color: #666;
    }

    .summary-row.total {
      border-top: 2px solid #e0e0e0;
      padding-top: 12px;
      font-size: 18px;
      font-weight: 700;
      color: #007bff;
    }

    .checkout-btn {
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 20px;
    }

    .checkout-btn:hover {
      box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
      transform: translateY(-2px);
    }

    .checkout-btn:disabled {
      background: #ccc;
      cursor: not-allowed;
      transform: none;
    }

    .continue-shopping {
      width: 100%;
      padding: 12px;
      background: #f0f0f0;
      color: #333;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      text-align: center;
      text-decoration: none;
      display: block;
    }

    .continue-shopping:hover {
      background: #e0e0e0;
    }

    .alert {
      padding: 15px;
      border-radius: 6px;
      margin-bottom: 20px;
    }

    .alert-info {
      background: #e7f3ff;
      border: 1px solid #b3d9ff;
      color: #004085;
    }

    .cart-activity {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 20px;
      font-size: 13px;
      color: #666;
    }

    .activity-item {
      padding: 10px 0;
      border-bottom: 1px solid #e0e0e0;
    }

    .activity-item:last-child {
      border-bottom: none;
    }

    @media (max-width: 768px) {
      .cart-summary {
        order: -1;
      }
    }
  </style>
</head>
<body>

  <%- include('partials/header') %>

  <main class="cart-container">
    <div class="cart-header">
      <h1><i class="fas fa-shopping-cart"></i> Your Shopping Cart</h1>
      <p style="color: #666;">Review your rental items before checkout</p>
    </div>

    <% if (!isLoggedIn) { %>
      <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> Please <a href="/login">log in</a> to view your cart
      </div>
    <% } %>

    <div class="cart-content">
      <!-- Cart Items -->
      <div class="cart-items">
        <% if (cartItems.length === 0) { %>
          <div class="empty-cart">
            <i class="fas fa-shopping-cart"></i>
            <p>Your cart is empty</p>
            <a href="/" class="continue-shopping" style="display: inline-block; padding: 10px 30px;">
              <i class="fas fa-arrow-left"></i> Browse Equipment
            </a>
          </div>
        <% } else { %>
          <% cartItems.forEach(function(item, index) { %>
            <div class="cart-item" data-item-index="<%= index %>">
              <div class="item-image">
                <% if (item.equipmentImage) { %>
                  <img src="<%= item.equipmentImage %>" alt="<%= item.equipmentName %>">
                <% } else { %>
                  <i class="fas fa-tools" style="font-size: 40px; color: #ccc;"></i>
                <% } %>
              </div>

              <div class="item-details">
                <div class="item-name"><%= item.equipmentName || 'Equipment' %></div>
                <div class="item-meta">
                  <strong>Daily Rate:</strong> $<%= item.dailyRate || 0 %>
                </div>
                <div class="item-dates">
                  <i class="fas fa-calendar-alt"></i>
                  <% 
                    const startDate = new Date(item.startDate);
                    const endDate = new Date(item.endDate);
                    const daysDiff = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24)) || 1;
                  %>
                  <%= startDate.toLocaleDateString() %> - <%= endDate.toLocaleDateString() %>
                  (<%= daysDiff %> day<%= daysDiff !== 1 ? 's' : '' %>)
                </div>
              </div>

              <div style="text-align: center; font-weight: 600; color: #333;">
                <%= item.quantity || 1 %>x
              </div>

              <div class="item-price">
                $<span class="price-value"><%= (item.subtotal || 0).toFixed(2) %></span>
                <button class="remove-btn" onclick="removeItem('<%= index %>')" title="Remove from cart">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>

      <!-- Cart Sidebar -->
      <div class="cart-sidebar">
        <!-- Order Summary -->
        <div class="cart-summary">
          <div class="summary-title">Order Summary</div>

          <div class="summary-row">
            <span>Subtotal (<%= cartItems.length %> item<%= cartItems.length !== 1 ? 's' : '' %>)</span>
            <span>$<span id="subtotal"><%= cartItems.reduce((sum, item) => sum + (item.subtotal || 0), 0).toFixed(2) %></span></span>
          </div>

          <div class="summary-row">
            <span>Delivery Fee</span>
            <span>$<span id="deliveryFee">0.00</span></span>
          </div>

          <div class="summary-row">
            <span>Tax (estimated)</span>
            <span>$<span id="tax"><%= (cartItems.reduce((sum, item) => sum + (item.subtotal || 0), 0) * 0.13).toFixed(2) %></span></span>
          </div>

          <div class="summary-row total">
            <span>Total</span>
            <span>$<span id="total"><%= (cartItems.reduce((sum, item) => sum + (item.subtotal || 0), 0) * 1.13).toFixed(2) %></span></span>
          </div>

          <% if (isLoggedIn && (cartItems.length > 0)) { %>
            <button class="checkout-btn" onclick="proceedToCheckout()">
              <i class="fas fa-lock"></i> Proceed to Checkout
            </button>
          <% } else if (!isLoggedIn) { %>
            <a href="/login?redirect=cart" class="checkout-btn" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">
              <i class="fas fa-sign-in-alt"></i> Login to Checkout
            </a>
          <% } %>

          <a href="/" class="continue-shopping" style="margin-top: 12px;">
            <i class="fas fa-arrow-left"></i> Continue Shopping
          </a>
        </div>

        <!-- Cart Activity -->
        <div class="cart-activity">
          <div style="font-weight: 600; margin-bottom: 15px;">
            <i class="fas fa-info-circle"></i> Cart Info
          </div>
          <div class="activity-item">
            <strong>Items:</strong> <%= cartItems.length %>
          </div>
          <div class="activity-item">
            <strong>Subtotal:</strong> $<%= cartItems.reduce((sum, item) => sum + (item.subtotal || 0), 0).toFixed(2) %>
          </div>
          <% if (cartItems.length > 0) { %>
            <div class="activity-item">
              <strong>Total Qty:</strong> <%= cartItems.reduce((sum, item) => sum + (item.quantity || 1), 0) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <div id="appData" data-logged-in="<%= isLoggedIn %>" data-cart-synced="<%= typeof cartSynced !== 'undefined' && cartSynced ? 'true' : 'false' %>" style="display:none;"></div>

  <%- include('partials/footer') %>

  <!-- Delete Confirmation Modal -->
  <div id="deleteModal" style="
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10000;
  ">
    <div style="
      background: white;
      border-radius: 12px;
      padding: 30px;
      max-width: 400px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.2);
      text-align: center;
    ">
      <div style="font-size: 50px; color: #dc3545; margin-bottom: 15px;">
        <i class="fas fa-exclamation-circle"></i>
      </div>
      <h2 style="color: #333; margin-bottom: 10px; font-size: 22px;">Remove Item?</h2>
      <p style="color: #666; margin-bottom: 25px; font-size: 15px; line-height: 1.6;">
        Are you sure you want to remove this item from your cart? This action cannot be undone.
      </p>
      <div style="display: flex; gap: 10px; justify-content: center;">
        <button id="cancelBtn" style="
          padding: 12px 30px;
          background: #6c757d;
          color: white;
          border: none;
          border-radius: 6px;
          cursor: pointer;
          font-weight: 600;
          transition: all 0.3s;
        " onmouseover="this.style.background='#5a6268'" onmouseout="this.style.background='#6c757d'">
          Cancel
        </button>
        <button id="confirmDeleteBtn" style="
          padding: 12px 30px;
          background: #dc3545;
          color: white;
          border: none;
          border-radius: 6px;
          cursor: pointer;
          font-weight: 600;
          transition: all 0.3s;
        " onmouseover="this.style.background='#c82333'" onmouseout="this.style.background='#dc3545'">
          Remove Item
        </button>
      </div>
    </div>
  </div>

  <script>
    var isLoggedIn = document.getElementById('appData').dataset.loggedIn === 'true';
    var cartSynced = document.getElementById('appData').dataset.cartSynced === 'true';
    let itemToDelete = null;

    function hideDeleteModal() {
      itemToDelete = null;
      document.getElementById('deleteModal').style.display = 'none';
    }

    function removeItem(itemId) {
      itemToDelete = itemId;
      document.getElementById('deleteModal').style.display = 'flex';
    }

    function removeItemLocal(index) {
      itemToDelete = index;
      document.getElementById('deleteModal').style.display = 'flex';
    }

    function updateQuantity(itemId, change) {
      fetch(`/api/cart/update/${itemId}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ quantityChange: change })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          location.reload();
        } else {
          alert(data.message || 'Error updating quantity');
        }
      })
      .catch(err => {
        console.error('Error:', err);
        alert('Error updating quantity');
      });
    }

    let localStorageItems = [];

    function loadLocalStorageItems() {
      const cart = JSON.parse(localStorage.getItem('cart')) || [];
      localStorageItems = cart;
      
      console.log('loadLocalStorageItems - cart items:', cart.length, 'isLoggedIn:', isLoggedIn);
      
      // Display localStorage items if user is NOT logged in
      if (cart.length > 0) {
        if (!isLoggedIn) {
          console.log('Displaying localStorage items for non-logged-in user');
          displayLocalStorageItems(cart);
        }
      }
    }

    function displayLocalStorageItems(items) {
      const cartItemsContainer = document.querySelector('.cart-items');
      
      if (!cartItemsContainer) {
        console.error('Cart items container not found');
        return;
      }
      
      if (items.length === 0) {
        console.log('No items to display');
        return;
      }

      // Clear empty cart message if present
      const emptyCart = cartItemsContainer.querySelector('.empty-cart');
      if (emptyCart) {
        console.log('Removing empty cart message');
        emptyCart.remove();
      }
      
      console.log('Displaying', items.length, 'items from localStorage');
      
      items.forEach((item, index) => {
        const itemDiv = document.createElement('div');
        itemDiv.className = 'cart-item';
        itemDiv.setAttribute('data-item-index', index);
        
        const startDate = new Date(item.startDate);
        const endDate = new Date(item.endDate);
        const daysDiff = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));
        
        itemDiv.innerHTML = `
          <div class="item-image">
            ${item.equipmentImage ? `<img src="${item.equipmentImage}" alt="${item.equipmentName}" style="width: 100%; height: 100%; object-fit: cover;">` : `<i class="fas fa-tools" style="font-size: 40px; color: #ccc;"></i>`}
          </div>

          <div class="item-details">
            <div class="item-name">${item.equipmentName || 'Equipment'}</div>
            <div class="item-meta">
              <strong>Daily Rate:</strong> $${parseFloat(item.dailyRate || 0).toFixed(2)}
            </div>
            <div class="item-dates">
              <i class="fas fa-calendar-alt"></i>
              ${startDate.toLocaleDateString()} - ${endDate.toLocaleDateString()}
              (${daysDiff} day${daysDiff !== 1 ? 's' : ''})
            </div>
          </div>

          <div style="text-align: center; font-weight: 600; color: #333;">
            ${item.quantity || 1}x
          </div>

          <div class="item-price">
            $<span class="price-value">${parseFloat(item.totalAmount || 0).toFixed(2)}</span>
            <button class="remove-btn" type="button" title="Remove from cart">
              <i class="fas fa-trash-alt"></i>
            </button>
          </div>
        `;
        
        cartItemsContainer.appendChild(itemDiv);
        
        // Add event listener for delete
        itemDiv.querySelector('.remove-btn').addEventListener('click', () => removeItemLocal(index));
      });
      
      updateSummary();
    }

    function removeItemLocal(index) {
      itemToDelete = index;
      document.getElementById('deleteModal').style.display = 'flex';
    }

    function updateSummary() {
      console.log('updateSummary - isLoggedIn:', isLoggedIn, 'localStorageItems:', localStorageItems.length);
      
      if (!isLoggedIn && localStorageItems.length > 0) {
        const subtotal = localStorageItems.reduce((sum, item) => sum + (item.totalAmount || 0), 0);
        const tax = subtotal * 0.13;
        const total = subtotal + tax;
        
        const subtotalEl = document.getElementById('subtotal');
        const taxEl = document.getElementById('tax');
        const totalEl = document.getElementById('total');
        
        if (subtotalEl) subtotalEl.textContent = subtotal.toFixed(2);
        if (taxEl) taxEl.textContent = tax.toFixed(2);
        if (totalEl) totalEl.textContent = total.toFixed(2);
        
        console.log('Updated summary - subtotal:', subtotal, 'tax:', tax, 'total:', total);
      }
    }

    function proceedToCheckout() {
      // Redirect to secure checkout page
      window.location.href = '/checkout';
    }

    // Sync localStorage cart items after login
    document.addEventListener('DOMContentLoaded', function() {
      loadLocalStorageItems();
      
      // Modal event listeners
      document.getElementById('cancelBtn').addEventListener('click', hideDeleteModal);
      document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
        if (itemToDelete !== null) {
          if (isLoggedIn) {
            // Logged-in user - database Cart item (pass index)
            fetch(`/api/cart/remove/${itemToDelete}`, {
              method: 'DELETE'
            })
            .then(res => {
              if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
              }
              return res.json();
            })
            .then(data => {
              if (data.success) {
                hideDeleteModal();
                
                // Trigger cart update event for header before reload
                window.dispatchEvent(new Event('cartUpdated'));
                
                location.reload();
              } else {
                hideDeleteModal();
                alert(data.message || 'Error removing item');
                console.error('Delete failed:', data);
              }
            })
            .catch(err => {
              console.error('Error:', err);
              hideDeleteModal();
              alert('Error removing item: ' + err.message);
            });
          } else {
            // Guest user - localStorage item
            localStorageItems.splice(itemToDelete, 1);
            localStorage.setItem('cart', JSON.stringify(localStorageItems));
            hideDeleteModal();
            
            // Trigger cart update event for header before reload
            window.dispatchEvent(new Event('cartUpdated'));
            
            location.reload();
          }
        }
      });
      
      // If cart was synced server-side on login, clear localStorage
      if (cartSynced) {
        localStorage.removeItem('cart');
      }
    });
  </script>

</body>
</html>
