<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Browse our complete catalog of equipment rentals including scissor lifts, boom lifts, forklifts, and more.">
  <title><%= title %></title>
  <link rel="icon" href="/images/Favicon.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/equipment.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="equipment-hero">
    <div>
      <h1>Equipment Catalog</h1>
      <p>Browse Our Complete Rental Inventory</p>
    </div>
  </section>

  <!-- Main Catalog -->
  <main class="equipment-catalog">

    <!-- Categories Accordion -->
    <section class="categories-section">
      <div class="categories-accordion">
        <% if (Object.keys(categories).length > 0) { %>
          <% Object.entries(categories).forEach(([category, items], index) => { %>
            <div class="category-accordion-item">
              <button class="category-accordion-header" data-category="<%= category %>">
                <span class="category-accordion-title"><%= category %></span>
                <span class="category-accordion-count">(<%= items.length %>)</span>
                <i class="fas fa-chevron-down category-accordion-icon"></i>
              </button>
              <div class="category-accordion-content" id="category-<%= index %>">
                <div class="equipment-grid">
                  <% items.forEach((item) => { %>
                    <div class="equipment-card">
                      <div class="equipment-card-image">
                        <% if (item.image) { %>
                          <img src="<%= item.image %>" alt="<%= item.name %>" style="width: 100%; height: 200px; object-fit: cover;">
                        <% } else { %>
                          <i class="fas fa-tools" style="font-size: 48px; color: #ccc;"></i>
                        <% } %>
                      </div>
                      <div class="equipment-card-content">
                        <h3><%= item.name %></h3>
                        <p><%= item.description %></p>
                        <div class="equipment-specs" style="font-size: 12px; color: #666; margin: 10px 0;">
                          <strong>Available:</strong> <%= item.quantityAvailable %> of <%= item.quantity %>
                        </div>
                        <div class="equipment-price">From $<%= item.dailyRate %>/day</div>
                        <div class="equipment-card-footer">
                          <a class="btn-quote" href="/equipment/<%= item._id %>/rent">Rent Now</a>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #999;">
            <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 15px; display: block;"></i>
            <p>No equipment available at the moment.</p>
          </div>
        <% } %>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <h2>Can't Find What You Need?</h2>
      <p>We have additional equipment available. Contact us for custom quotes, multi-item packages, and long-term rental discounts.</p>
      <a href="/contact" class="cta-btn">Request Custom Quote</a>
    </section>

  </main>

  <%- include('partials/footer') %>

  <script>
    // Set initial state - hide all accordion content
    const accordionContents = document.querySelectorAll('.category-accordion-content');
    accordionContents.forEach(content => {
      content.style.display = 'none';
    });

    // Accordion functionality
    const accordionHeaders = document.querySelectorAll('.category-accordion-header');
    
    accordionHeaders.forEach(header => {
      header.addEventListener('click', function() {
        const category = this.getAttribute('data-category');
        const content = this.nextElementSibling;
        const icon = this.querySelector('.category-accordion-icon');
        
        // Toggle active state
        this.classList.toggle('active');
        
        // Toggle content visibility
        if (content.style.display === 'block') {
          content.style.display = 'none';
          icon.style.transform = 'rotate(0deg)';
        } else {
          content.style.display = 'block';
          icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  </script>



</body>
</html>
