<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders Management - JC Rentals Admin</title>
  <link rel="icon" href="/images/Favicon.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    :root {
      --primary:       #B7E35A;
      --primary-dark:  #2F4F4A;
      --success:       #10b981;
      --warning:       #f59e0b;
      --danger:        #ef4444;
      --info:          #3b82f6;
      --purple:        #6366f1;
      --bg:            #f4f6f8;
      --border:        #e5e7eb;
      --text:          #1f2937;
      --muted:         #6b7280;
      --white:         #ffffff;
      --radius:        12px;
      --shadow-sm:     0 1px 4px rgba(0,0,0,.07);
      --shadow-md:     0 4px 16px rgba(0,0,0,.10);
    }

    body { background: var(--bg); overflow-x: hidden; }

    /* ── Page header ── */
    .page-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 1.75rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .page-header h2 {
      margin: 0;
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--primary-dark);
      letter-spacing: -.5px;
    }
    .page-header p { margin: .25rem 0 0; color: var(--muted); font-size: .9rem; }

    /* ── Stat cards ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0.75rem;
      margin-bottom: 1.75rem;
    }
    .stat-pill {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      box-shadow: var(--shadow-sm);
      border-left: 4px solid var(--accent, #ccc);
      transition: all .2s;
      box-sizing: border-box;
      min-width: 0;
    }
    .stat-pill:hover { 
      box-shadow: var(--shadow-md);
      transform: translateY(-4px);
    }
    .stat-pill-icon {
      width: 40px; height: 40px;
      border-radius: 8px;
      background: var(--accent-bg, #f3f4f6);
      color: var(--accent, #888);
      display: flex; 
      align-items: center; 
      justify-content: center;
      font-size: 1rem; 
      flex-shrink: 0;
    }
    .stat-pill-body { width: 100%; }
    .stat-pill-value { font-size: 1.5rem; font-weight: 800; color: var(--primary-dark); line-height: 1; }
    .stat-pill-label { font-size: 0.7rem; color: var(--muted); margin-top: 0.2rem; text-transform: uppercase; letter-spacing: .4px; }

    /* ── Toolbar ── */
    .toolbar {
      display: flex;
      align-items: center;
      gap: .75rem;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
    }
    .search-wrap {
      position: relative;
      flex: 1;
      min-width: 180px;
      max-width: 360px;
    }
    .search-wrap i { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: var(--muted); pointer-events: none; font-size: .85rem; }
    .search-wrap input {
      width: 100%; padding: .65rem .9rem .65rem 2.4rem;
      border: 1.5px solid var(--border); border-radius: 8px;
      font-size: .9rem; background: var(--white); color: var(--text);
      transition: border-color .2s, box-shadow .2s;
      box-sizing: border-box;
    }
    .search-wrap input:focus { outline: none; border-color: var(--primary-dark); box-shadow: 0 0 0 3px rgba(47,79,74,.1); }

    /* ── Filter tabs ── */
    .filter-tabs {
      display: flex;
      gap: .4rem;
      flex-wrap: wrap;
    }
    .ftab {
      padding: .45rem 1rem;
      border-radius: 20px;
      border: 1.5px solid var(--border);
      background: var(--white);
      font-size: .8rem;
      font-weight: 600;
      color: var(--muted);
      cursor: pointer;
      transition: all .2s;
      white-space: nowrap;
    }
    .ftab:hover { border-color: var(--primary-dark); color: var(--primary-dark); }
    .ftab.active { background: var(--primary-dark); border-color: var(--primary-dark); color: var(--white); }

    /* ── Table card ── */
    .table-card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      min-width: 0;
    }
    .table-scroll { overflow-x: auto; width: 100%; }
    .orders-table { width: 100%; border-collapse: collapse; }
    .orders-table thead { background: #f9fafb; border-bottom: 2px solid var(--border); }
    .orders-table th {
      padding: .85rem 1rem;
      text-align: left;
      font-size: .72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .6px;
      color: var(--muted);
      white-space: nowrap;
    }
    .orders-table td {
      padding: .9rem 1rem;
      font-size: .875rem;
      color: var(--text);
      border-bottom: 1px solid #f3f4f6;
      vertical-align: middle;
    }
    .orders-table tbody tr { transition: background .15s; }
    .orders-table tbody tr:hover { background: #f9fafb; }
    .orders-table tbody tr:last-child td { border-bottom: none; }

    .order-id { font-weight: 700; color: var(--primary-dark); font-size: .8rem; letter-spacing: .3px; }
    .customer-cell { display: flex; align-items: center; gap: .6rem; }
    .customer-avatar {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, var(--primary), #a8d949);
      color: var(--primary-dark); font-weight: 700; font-size: .75rem;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .customer-name { font-weight: 600; font-size: .875rem; }
    .equipment-text { color: var(--muted); font-size: .82rem; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .eq-more { display: inline-block; background: #e5e7eb; color: var(--muted); font-size: .7rem; font-weight: 700; padding: .1rem .45rem; border-radius: 10px; margin-left: .35rem; vertical-align: middle; white-space: nowrap; }
    .amount-cell { font-weight: 700; color: var(--primary-dark); }
    .days-badge { background: #f3f4f6; color: var(--muted); padding: .2rem .55rem; border-radius: 6px; font-size: .75rem; white-space: nowrap; }
    .date-cell { color: var(--muted); font-size: .82rem; white-space: nowrap; }

    /* status badges */
    .sbadge {
      display: inline-flex; align-items: center; gap: .35rem;
      padding: .3rem .75rem; border-radius: 20px;
      font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .4px;
      white-space: nowrap;
    }
    .sbadge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: .7; }
    .sbadge.pending   { background: rgba(245,158,11,.12);  color: #b45309; }
    .sbadge.confirmed { background: rgba(59,130,246,.12);  color: #1d4ed8; }
    .sbadge.active    { background: rgba(16,185,129,.12);  color: #047857; }
    .sbadge.returned  { background: rgba(168,85,247,.12);  color: #7e22ce; }
    .sbadge.completed { background: rgba(99,102,241,.12);  color: #4338ca; }
    .sbadge.cancelled { background: rgba(239,68,68,.12);   color: #b91c1c; }

    /* row actions */
    .row-actions { display: flex; gap: .4rem; }
    .raction {
      width: 30px; height: 30px; border: none; border-radius: 7px;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      font-size: .8rem; transition: all .2s;
    }
    .raction-view   { background: #e0f0ff; color: #1d4ed8; }
    .raction-view:hover   { background: #1d4ed8; color: white; }
    .raction-status { background: #f0fdf4; color: #16a34a; }
    .raction-status:hover { background: #16a34a; color: white; }
    .raction-delete { background: #ffebee; color: #b91c1c; }
    .raction-delete:hover { background: #b91c1c; color: white; }

    /* empty state */
    .empty-state {
      text-align: center; padding: 4rem 2rem; color: var(--muted);
    }
    .empty-state i { font-size: 3rem; opacity: .2; display: block; margin-bottom: 1rem; }
    .empty-state p { margin: 0; font-size: .95rem; }
    .empty-state .empty-sub { font-size: .82rem; margin-top: .4rem; opacity: .7; }
    #noResultsRow { display: none; }
    #noResultsRow td { border: none; }

    /* ── Modal ── */
    .admin-modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 1000; align-items: center; justify-content: center; padding: 1rem; }
    .admin-modal.active { display: flex; }
    .modal-box {
      background: var(--white); border-radius: 16px; width: 100%; max-width: 580px;
      max-height: 88vh; overflow-y: auto; box-shadow: 0 24px 64px rgba(0,0,0,.18);
      display: flex; flex-direction: column; animation: popIn .25s ease;
    }
    @keyframes popIn { from { transform: scale(.95) translateY(12px); opacity: 0; } to { transform: none; opacity: 1; } }

    .modal-head {
      padding: 1.4rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      background: linear-gradient(135deg, var(--primary-dark), #1a3530);
      border-radius: 16px 16px 0 0;
    }
    .modal-head-left { display: flex; align-items: center; gap: .75rem; }
    .modal-head-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: rgba(183,227,90,.2); color: var(--primary);
      display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
    }
    .modal-head h2 { margin: 0; font-size: 1.1rem; font-weight: 700; color: white; }
    .modal-head p  { margin: .15rem 0 0; font-size: .78rem; color: rgba(255,255,255,.55); }
    .modal-x {
      background: rgba(255,255,255,.1); border: none; color: rgba(255,255,255,.7);
      width: 32px; height: 32px; border-radius: 8px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 1rem;
      transition: background .2s;
    }
    .modal-x:hover { background: rgba(255,255,255,.2); color: white; }

    .modal-body { padding: 1.5rem; flex: 1; }
    .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .modal-section { margin-bottom: 1.25rem; }
    .modal-section:last-child { margin-bottom: 0; }
    .modal-section-title {
      font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .6px;
      color: var(--muted); margin-bottom: .6rem; display: flex; align-items: center; gap: .4rem;
    }
    .modal-section-title i { color: var(--primary-dark); }
    .modal-field {
      background: #f9fafb; border-radius: 8px; padding: .65rem .9rem;
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: .4rem; gap: .5rem;
    }
    .modal-field:last-child { margin-bottom: 0; }
    .modal-field label { font-size: .8rem; color: var(--muted); font-weight: 500; white-space: nowrap; }
    .modal-field span  { font-size: .875rem; color: var(--text); font-weight: 600; text-align: right; }
    .modal-field .big-amount { font-size: 1.25rem; font-weight: 800; color: var(--primary-dark); }

    .modal-foot {
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      display: flex; justify-content: flex-end;
    }
    .btn-close-modal {
      padding: .65rem 1.5rem; border-radius: 8px;
      border: 1.5px solid var(--border); background: white;
      color: var(--text); font-weight: 600; font-size: .875rem;
      cursor: pointer; transition: all .2s;
    }
    .btn-close-modal:hover { background: var(--bg); border-color: var(--primary-dark); }

    /* Status Confirmation Modal */
    .status-confirm-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1100;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .status-confirm-modal.active {
      display: flex;
    }
    .status-confirm-box {
      background: white;
      border-radius: 12px;
      width: 100%;
      max-width: 400px;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }
    .status-confirm-head {
      background: linear-gradient(135deg, var(--primary-dark), #1a3530);
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      color: white;
    }
    .status-confirm-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }
    .status-confirm-head h3 {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
    }
    .status-confirm-body {
      padding: 1.5rem;
      text-align: center;
    }
    .status-confirm-body p {
      margin: 0 0 1.5rem;
      color: var(--text);
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .status-confirm-body .status-value {
      display: inline-block;
      background: #f0fdf4;
      color: #16a34a;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-weight: 600;
      margin: 0.5rem 0;
    }
    .status-confirm-actions {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
    }
    .status-confirm-btn {
      padding: 0.65rem 1.5rem;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.875rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .status-confirm-btn-confirm {
      background: #16a34a;
      color: white;
    }
    .status-confirm-btn-confirm:hover {
      background: #15803d;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(22, 163, 74, 0.3);
    }
    .status-confirm-btn-cancel {
      background: #f3f4f6;
      color: var(--text);
      border: 1.5px solid #e5e7eb;
    }
    .status-confirm-btn-cancel:hover {
      background: #e5e7eb;
      border-color: var(--text);
    }

    /* Delete Confirmation Modal */
    .delete-confirm-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1100;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .delete-confirm-modal.active {
      display: flex;
    }
    .delete-confirm-box {
      background: white;
      border-radius: 12px;
      width: 100%;
      max-width: 400px;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }
    .delete-confirm-head {
      background: linear-gradient(135deg, #dc2626, #991b1b);
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      color: white;
    }
    .delete-confirm-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }
    .delete-confirm-head h3 {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
    }
    .delete-confirm-body {
      padding: 1.5rem;
      text-align: center;
    }
    .delete-confirm-body p {
      margin: 0 0 1.5rem;
      color: var(--text);
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .delete-confirm-actions {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      padding: 0 1.5rem 1.5rem;
    }
    .delete-confirm-btn {
      padding: 0.65rem 1.5rem;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.875rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .delete-confirm-btn-confirm {
      background: #dc2626;
      color: white;
    }
    .delete-confirm-btn-confirm:hover {
      background: #b91c1c;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
    }
    .delete-confirm-btn-cancel {
      background: #f3f4f6;
      color: var(--text);
      border: 1.5px solid #e5e7eb;
    }
    .delete-confirm-btn-cancel:hover {
      background: #e5e7eb;
      border-color: var(--text);
    }
    @media (max-width: 1024px) {
      .stats-row {
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 0.6rem;
      }
      .stat-pill {
        padding: 1rem;
        gap: 0.4rem;
      }
      .stat-pill-value { font-size: 1.3rem; }
    }
    @media (max-width: 768px) {
      .stats-row { 
        grid-template-columns: repeat(2, 1fr);
        gap: 0.6rem;
      }
      .stat-pill {
        padding: 0.9rem;
        gap: 0.35rem;
      }
      .stat-pill-icon { width: 36px; height: 36px; font-size: 0.9rem; }
      .stat-pill-value { font-size: 1.2rem; }
      .stat-pill-label { font-size: 0.65rem; }
      .search-wrap {
        min-width: 120px;
        max-width: 100%;
      }
      .orders-table th:nth-child(4),
      .orders-table td:nth-child(4),
      .orders-table th:nth-child(5),
      .orders-table td:nth-child(5) { display: none; }
      .modal-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .toolbar {
        flex-direction: column;
        align-items: stretch;
        gap: 0.5rem;
      }
      .stats-row { 
        grid-template-columns: repeat(2, 1fr);
        gap: 0.4rem;
      }
      .stat-pill {
        padding: 0.65rem 0.75rem;
        gap: 0.2rem;
      }
      .stat-pill-icon { width: 30px; height: 30px; font-size: 0.75rem; }
      .stat-pill-value { font-size: 0.9rem; }
      .stat-pill-label { font-size: 0.55rem; }
      .search-wrap {
        min-width: 100%;
        max-width: 100%;
      }
      .search-wrap input {
        padding: 0.6rem 0.8rem 0.6rem 2.2rem;
        font-size: 0.8rem;
      }
      .search-wrap i { left: 10px; font-size: 0.75rem; }
      .filter-tabs {
        overflow-x: auto;
      }
      .orders-table th:nth-child(3),
      .orders-table td:nth-child(3) { display: none; }
    }
  </style>
</head>
<body>
  <div class="admin-wrapper">
    <% locals.currentPage = 'orders'; %>
    <%- include('partials/sidebar') %>

    <main class="admin-main">
      <% locals.pageTitle = 'Orders Management'; %>
      <%- include('partials/topbar') %>

      <div class="admin-content">

        <!-- Header -->
        <div class="page-header">
          <div>
            <h2>Orders</h2>
            <p>Monitor and manage all customer rental orders</p>
          </div>
        </div>

        <%
          const allOrders = orders || [];
          const totalRevenue = allOrders.reduce((s, o) => s + (o.totalAmount || 0), 0);
          const countByStatus = (s) => allOrders.filter(o => o.status === s).length;
        %>

        <!-- Stat cards -->
        <div class="stats-row">
          <div class="stat-pill" style="--accent:#2F4F4A;--accent-bg:rgba(47,79,74,.1)">
            <div class="stat-pill-icon"><i class="fas fa-receipt"></i></div>
            <div class="stat-pill-body">
              <div class="stat-pill-value"><%= allOrders.length %></div>
              <div class="stat-pill-label">Total Orders</div>
            </div>
          </div>
          <div class="stat-pill" style="--accent:#B7E35A;--accent-bg:rgba(183,227,90,.15)">
            <div class="stat-pill-icon"><i class="fas fa-dollar-sign"></i></div>
            <div class="stat-pill-body">
              <div class="stat-pill-value">$<%= totalRevenue.toFixed(0) %></div>
              <div class="stat-pill-label">Total Revenue</div>
            </div>
          </div>
          <div class="stat-pill" style="--accent:#f59e0b;--accent-bg:rgba(245,158,11,.1)">
            <div class="stat-pill-icon"><i class="fas fa-clock"></i></div>
            <div class="stat-pill-body">
              <div class="stat-pill-value"><%= countByStatus('pending') %></div>
              <div class="stat-pill-label">Pending</div>
            </div>
          </div>

          <div class="stat-pill" style="--accent:#6366f1;--accent-bg:rgba(99,102,241,.1)">
            <div class="stat-pill-icon"><i class="fas fa-flag-checkered"></i></div>
            <div class="stat-pill-body">
              <div class="stat-pill-value"><%= countByStatus('completed') %></div>
              <div class="stat-pill-label">Completed</div>
            </div>
          </div>
          <div class="stat-pill" style="--accent:#ef4444;--accent-bg:rgba(239,68,68,.1)">
            <div class="stat-pill-icon"><i class="fas fa-times-circle"></i></div>
            <div class="stat-pill-body">
              <div class="stat-pill-value"><%= countByStatus('cancelled') %></div>
              <div class="stat-pill-label">Cancelled</div>
            </div>
          </div>
        </div>

        <!-- Toolbar -->
        <div class="toolbar">
          <div class="search-wrap">
            <i class="fas fa-search"></i>
            <input type="text" id="orderSearch" placeholder="Search order ID or customer…">
          </div>
          <div class="filter-tabs">
            <button class="ftab active" data-filter="all">All</button>
            <button class="ftab" data-filter="pending">Pending</button>
            <button class="ftab" data-filter="confirmed">Confirmed</button>
            <button class="ftab" data-filter="active">Active</button>
            <button class="ftab" data-filter="completed">Completed</button>
            <button class="ftab" data-filter="cancelled">Cancelled</button>
          </div>
        </div>

        <!-- Table -->
        <div class="table-card">
          <% if (allOrders.length === 0) { %>
            <div class="empty-state">
              <i class="fas fa-inbox"></i>
              <p>No orders found</p>
            </div>
          <% } else { %>
          <div class="table-scroll">
            <table class="orders-table">
              <thead>
                <tr>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Equipment</th>
                  <th>Date</th>
                  <th>Duration</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="ordersTableBody">
                <% allOrders.forEach(order => {
                  const customer = order.userId ? `${order.userId.firstName} ${order.userId.lastName}` : 'Unknown';
                  const initials = order.userId ? `${(order.userId.firstName||'?')[0]}${(order.userId.lastName||'?')[0]}` : '?';
                  const itemCount = order.items ? order.items.length : 0;
                  const equipment = itemCount > 0 ? order.items[0].equipmentName : '-';
                  const equipmentFull = order.items ? order.items.map(i => i.equipmentName).join(', ') : '-';
                  const days = order.rentalPeriod && order.rentalPeriod.days
                    ? order.rentalPeriod.days
                    : (order.items && order.items[0] && order.items[0].startDate && order.items[0].endDate
                      ? Math.ceil((new Date(order.items[0].endDate) - new Date(order.items[0].startDate)) / (1000*60*60*24))
                      : null);
                  const orderId = order.orderNumber || String(order._id).slice(-6).toUpperCase();
                %>
                <tr data-status="<%= order.status %>"
                    data-customer="<%= customer.toLowerCase() %>"
                    data-ordernum="<%= orderId.toLowerCase() %>">
                  <td><span class="order-id">#<%= orderId %></span></td>
                  <td>
                    <div class="customer-cell">
                      <div class="customer-avatar"><%= initials.toUpperCase() %></div>
                      <span class="customer-name"><%= customer %></span>
                    </div>
                  </td>
                  <td>
                    <span class="equipment-text" title="<%= equipmentFull %>"><%= equipment %></span>
                    <% if (itemCount > 1) { %><span class="eq-more">+<%= itemCount - 1 %></span><% } %>
                  </td>
                  <td><span class="date-cell"><%= new Date(order.createdAt).toLocaleDateString() %></span></td>
                  <td>
                    <% if (days) { %>
                      <span class="days-badge"><i class="fas fa-calendar-alt"></i> <%= days %>d</span>
                    <% } else { %>
                      <span class="date-cell">—</span>
                    <% } %>
                  </td>
                  <td><span class="amount-cell">$<%= order.totalAmount.toFixed(2) %></span></td>
                  <td><span class="sbadge <%= order.status %>"><%= order.status %></span></td>
                  <td>
                    <div class="row-actions">
                      <button class="raction raction-view" onclick="viewOrder('<%= order._id %>')" title="View details"><i class="fas fa-eye"></i></button>
                      <button class="raction raction-status" onclick="updateStatus('<%= order._id %>', '<%= order.status %>')" title="Update status"><i class="fas fa-<%= order.status === 'returned' ? 'undo' : 'check' %>"></i></button>
                      <button class="raction raction-delete" onclick="deleteOrder('<%= order._id %>')" title="Delete"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <tr id="noResultsRow">
                  <td colspan="8">
                    <div class="empty-state">
                      <i class="fas fa-search"></i>
                      <p>No orders match your search</p>
                      <p class="empty-sub">Try a different filter or search term</p>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

      </div>
    </main>
  </div>

  <%- include('partials/sidebar-script') %>

  <!-- Order Details Modal -->
  <div id="orderModal" class="admin-modal">
    <div class="modal-box">
      <div class="modal-head">
        <div class="modal-head-left">
          <div class="modal-head-icon"><i class="fas fa-receipt"></i></div>
          <div>
            <h2>Order Details</h2>
            <p id="modalOrderId">—</p>
          </div>
        </div>
        <button class="modal-x modal-close"><i class="fas fa-times"></i></button>
      </div>
      <div class="modal-body" id="orderModalBody"></div>
      <div class="modal-foot">
        <button class="btn-close-modal modal-close">Close</button>
      </div>
    </div>
  </div>

  <!-- Status Confirmation Modal -->
  <div id="statusConfirmModal" class="status-confirm-modal">
    <div class="status-confirm-box">
      <div class="status-confirm-head">
        <div class="status-confirm-icon">
          <i class="fas fa-check-circle"></i>
        </div>
        <h3 id="statusConfirmTitle">Confirm Status Change</h3>
      </div>
      <div class="status-confirm-body">
        <p>
          Are you sure you want to change the status to:
          <div class="status-value" id="statusConfirmValue">—</div>
        </p>
      </div>
      <div style="padding: 0 1.5rem 1.5rem;">
        <div class="status-confirm-actions">
          <button class="status-confirm-btn status-confirm-btn-cancel" id="statusConfirmCancel">Cancel</button>
          <button class="status-confirm-btn status-confirm-btn-confirm" id="statusConfirmOk">Confirm</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteConfirmModal" class="delete-confirm-modal">
    <div class="delete-confirm-box">
      <div class="delete-confirm-head">
        <div class="delete-confirm-icon">
          <i class="fas fa-trash-alt"></i>
        </div>
        <h3>Delete Order</h3>
      </div>
      <div class="delete-confirm-body">
        <p><strong>Delete this order?</strong><br>This cannot be undone.</p>
      </div>
      <div class="delete-confirm-actions">
        <button class="delete-confirm-btn delete-confirm-btn-cancel" id="deleteConfirmCancel">Cancel</button>
        <button class="delete-confirm-btn delete-confirm-btn-confirm" id="deleteConfirmOk">Delete</button>
      </div>
    </div>
  </div>

  <!-- Data storage -->
  <script type="application/json" id="ordersDataJson"><%- JSON.stringify(orders || []) %></script>

  <script>
    const ordersData = JSON.parse(document.getElementById('ordersDataJson').textContent);

    function viewOrder(orderId) {
      const order = ordersData.find(o => o._id === orderId);
      if (!order) return;

      const days = order.rentalPeriod && order.rentalPeriod.days
        ? order.rentalPeriod.days
        : (order.items?.[0]?.startDate && order.items?.[0]?.endDate
          ? Math.ceil((new Date(order.items[0].endDate) - new Date(order.items[0].startDate)) / 86400000)
          : '—');
      const customer  = order.userId ? `${order.userId.firstName} ${order.userId.lastName}` : 'Unknown';
      const itemNames = order.items ? order.items.map(i => i.equipmentName) : [];
      const equipment = itemNames.length > 0 ? itemNames[0] : '—';
      const equipExtra = itemNames.length > 1 ? ` <span class="eq-more">+${itemNames.length - 1} more</span>` : '';
      const startDate = order.rentalPeriod?.startDate
        ? new Date(order.rentalPeriod.startDate).toLocaleDateString()
        : (order.items?.[0]?.startDate ? new Date(order.items[0].startDate).toLocaleDateString() : '—');
      const endDate = order.rentalPeriod?.endDate
        ? new Date(order.rentalPeriod.endDate).toLocaleDateString()
        : (order.items?.[0]?.endDate ? new Date(order.items[0].endDate).toLocaleDateString() : '—');
      const orderId2 = order.orderNumber || order._id;

      document.getElementById('modalOrderId').textContent = '#' + (order.orderNumber || String(order._id).slice(-6).toUpperCase());

      document.getElementById('orderModalBody').innerHTML = `
        <div class="modal-section">
          <div class="modal-section-title"><i class="fas fa-info-circle"></i> Order Information</div>
          <div class="modal-field"><label>Order ID</label><span>${orderId2}</span></div>
          <div class="modal-field"><label>Order Date</label><span>${new Date(order.createdAt).toLocaleDateString()}</span></div>
          <div class="modal-field"><label>Status</label><span class="sbadge ${order.status}">${order.status}</span></div>
        </div>
        <div class="modal-section">
          <div class="modal-section-title"><i class="fas fa-user"></i> Customer</div>
          <div class="modal-field"><label>Name</label><span>${customer}</span></div>
        </div>
        <div class="modal-section">
          <div class="modal-section-title"><i class="fas fa-tools"></i> Rental Details</div>
          <div class="modal-field"><label>Equipment</label><span>${equipment}${equipExtra}</span></div>
          <div class="modal-field"><label>Start Date</label><span>${startDate}</span></div>
          <div class="modal-field"><label>End Date</label><span>${endDate}</span></div>
          <div class="modal-field"><label>Duration</label><span>${days} days</span></div>
        </div>
        <div class="modal-section">
          <div class="modal-section-title"><i class="fas fa-dollar-sign"></i> Billing</div>
          <div class="modal-field"><label>Total Amount</label><span class="big-amount">$${order.totalAmount.toFixed(2)}</span></div>
        </div>
      `;
      document.getElementById('orderModal').classList.add('active');
    }

    function deleteOrder(orderId) {
      const modal = document.getElementById('deleteConfirmModal');
      modal.classList.add('active');

      const handleConfirm = () => {
        modal.classList.remove('active');
        document.getElementById('deleteConfirmOk').removeEventListener('click', handleConfirm);
        document.getElementById('deleteConfirmCancel').removeEventListener('click', handleCancel);

        fetch(`/admin/api/orders/${orderId}`, { method: 'DELETE' })
          .then(r => r.json())
          .then(d => {
            if (d.success) {
              location.reload();
            } else {
              alert(d.message || 'Error deleting order');
            }
          })
          .catch(() => alert('Error deleting order'));
      };

      const handleCancel = () => {
        modal.classList.remove('active');
        document.getElementById('deleteConfirmOk').removeEventListener('click', handleConfirm);
        document.getElementById('deleteConfirmCancel').removeEventListener('click', handleCancel);
      };

      document.getElementById('deleteConfirmOk').addEventListener('click', handleConfirm);
      document.getElementById('deleteConfirmCancel').addEventListener('click', handleCancel);
    }

    function updateStatus(orderId, currentStatus) {
      // Toggle between 'active' and 'returned'
      const newStatus = currentStatus === 'returned' ? 'active' : 'returned';
      const statusText = newStatus === 'returned' ? 'Mark as Returned' : 'Mark as Active';
      
      // Show custom confirmation modal
      document.getElementById('statusConfirmTitle').textContent = statusText;
      document.getElementById('statusConfirmValue').textContent = newStatus.toUpperCase();
      
      const modal = document.getElementById('statusConfirmModal');
      modal.classList.add('active');

      // Handle confirm
      const handleConfirm = () => {
        modal.classList.remove('active');
        document.getElementById('statusConfirmOk').removeEventListener('click', handleConfirm);
        document.getElementById('statusConfirmCancel').removeEventListener('click', handleCancel);

        fetch(`/admin/api/orders/${orderId}/status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus })
        })
          .then(r => r.json())
          .then(d => {
            if (d.success) {
              location.reload();
            } else {
              alert(d.message || 'Error updating status');
            }
          })
          .catch(err => {
            console.error('Error:', err);
            alert('Error updating order status');
          });
      };

      // Handle cancel
      const handleCancel = () => {
        modal.classList.remove('active');
        document.getElementById('statusConfirmOk').removeEventListener('click', handleConfirm);
        document.getElementById('statusConfirmCancel').removeEventListener('click', handleCancel);
      };

      document.getElementById('statusConfirmOk').addEventListener('click', handleConfirm);
      document.getElementById('statusConfirmCancel').addEventListener('click', handleCancel);
    }

    document.querySelectorAll('.modal-close').forEach(btn =>
      btn.addEventListener('click', () => document.getElementById('orderModal').classList.remove('active'))
    );

    // Filter tabs
    document.querySelectorAll('.ftab').forEach(tab => {
      tab.addEventListener('click', function () {
        document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        applyFilters();
      });
    });

    // Search
    document.getElementById('orderSearch').addEventListener('input', applyFilters);

    function applyFilters() {
      const q      = document.getElementById('orderSearch').value.toLowerCase();
      const status = document.querySelector('.ftab.active').dataset.filter;
      document.querySelectorAll('#ordersTableBody tr').forEach(row => {
        const matchSearch = !q || row.dataset.customer.includes(q) || row.dataset.ordernum.includes(q);
        const matchStatus = status === 'all' || row.dataset.status === status;
        row.style.display = matchSearch && matchStatus ? '' : 'none';
      });
      const anyVisible = [...document.querySelectorAll('#ordersTableBody tr:not(#noResultsRow)')].some(r => r.style.display !== 'none');
      document.getElementById('noResultsRow').style.display = anyVisible ? 'none' : 'table-row';
    }
  </script>
</body>
</html>
