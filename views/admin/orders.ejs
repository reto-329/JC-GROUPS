<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="JC Rentals Admin - Orders Management">
  <title>Orders Management - JC Rentals Admin</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-orders-page">
  <div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <div class="admin-logo-mini">
          <i class="fas fa-leaf"></i>
        </div>
        <h2>Admin Panel</h2>
      </div>

      <nav class="admin-nav">
        <a href="/admin/dashboard" class="nav-item">
          <i class="fas fa-chart-line"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/users" class="nav-item">
          <i class="fas fa-users"></i>
          <span>Users</span>
        </a>
        <a href="/admin/equipment" class="nav-item">
          <i class="fas fa-tools"></i>
          <span>Equipment</span>
        </a>
        <a href="/admin/orders" class="nav-item active">
          <i class="fas fa-shopping-cart"></i>
          <span>Orders</span>
        </a>
      </nav>

      <div class="admin-sidebar-footer">
        <a href="/admin/logout" class="logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <!-- Top Bar -->
      <div class="admin-topbar">
        <div class="topbar-left">
          <button class="admin-hamburger" id="adminHamburger" aria-label="Toggle sidebar">
            <span></span>
            <span></span>
            <span></span>
          </button>
          <div>
            <h1>Orders Management</h1>
            <p class="breadcrumb">Dashboard / Orders</p>
          </div>
        </div>
        <div class="topbar-right">
          <div class="admin-user-info">
            <span class="admin-name"><%= adminName %></span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="admin-content">
        <div class="content-header">
          <h2>All Orders</h2>
          <p class="text-muted">Monitor and manage customer rental orders</p>
        </div>

        <!-- Search and Filter -->
        <div class="management-toolbar">
          <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="orderSearch" placeholder="Search by order ID or customer...">
          </div>
          <div class="filter-options">
            <select id="statusFilter">
              <option value="">All Status</option>
              <option value="pending">Pending</option>
              <option value="confirmed">Confirmed</option>
              <option value="active">Active Rental</option>
              <option value="completed">Completed</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </div>
        </div>

        <!-- Orders Table -->
        <div class="table-container">
          <table class="management-table">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Equipment</th>
                <th>Order Date</th>
                <th>Rental Period</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="ordersTableBody">
              <tr class="no-data">
                <td colspan="8">
                  <i class="fas fa-inbox"></i>
                  <p>No orders found.</p>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="pagination">
          <button class="page-btn prev-btn" disabled>
            <i class="fas fa-chevron-left"></i> Previous
          </button>
          <div class="page-info">
            <span id="pageNumber">1</span> of <span id="totalPages">1</span>
          </div>
          <button class="page-btn next-btn">
            Next <i class="fas fa-chevron-right"></i>
          </button>
        </div>
      </div>
    </main>
  </div>

  <script>
    // Hamburger menu toggle
    const hamburger = document.getElementById('adminHamburger');
    const sidebar = document.querySelector('.admin-sidebar');

    if (hamburger) {
      hamburger.addEventListener('click', () => {
        sidebar.classList.toggle('active');
        hamburger.classList.toggle('active');
      });

      // Close sidebar when clicking a nav item
      document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', () => {
          sidebar.classList.remove('active');
          hamburger.classList.remove('active');
        });
      });

      // Close sidebar when clicking outside
      document.addEventListener('click', (e) => {
        if (!sidebar.contains(e.target) && !hamburger.contains(e.target)) {
          sidebar.classList.remove('active');
          hamburger.classList.remove('active');
        }
      });
    }
  </script>

  <!-- Order Details Modal -->
  <div id="orderModal" class="admin-modal">
    <div class="modal-content-lg">
      <div class="modal-header">
        <h2>Order Details</h2>
        <button class="modal-close">&times;</button>
      </div>
      <div class="modal-body" id="orderModalBody">
        <!-- Loaded dynamically -->
      </div>
      <div class="modal-footer">
        <button class="btn-secondary modal-close">Close</button>
      </div>
    </div>
  </div>

  <script>
    // Sample orders data
    const sampleOrders = [
      {
        id: 'ORD-001',
        customer: 'John Doe',
        equipment: 'Drill',
        orderDate: '2024-01-20',
        startDate: '2024-01-21',
        endDate: '2024-01-23',
        amount: 75.00,
        status: 'active'
      },
      {
        id: 'ORD-002',
        customer: 'Jane Smith',
        equipment: 'Hammer Set, Saw',
        orderDate: '2024-01-18',
        startDate: '2024-01-19',
        endDate: '2024-01-20',
        amount: 85.00,
        status: 'completed'
      },
      {
        id: 'ORD-003',
        customer: 'Bob Johnson',
        equipment: 'Wrench Set',
        orderDate: '2024-01-21',
        startDate: '2024-01-22',
        endDate: '2024-01-25',
        amount: 45.00,
        status: 'confirmed'
      },
    ];

    function renderOrders() {
      const tbody = document.getElementById('ordersTableBody');
      
      if (sampleOrders.length === 0) {
        tbody.innerHTML = '<tr class="no-data"><td colspan="8"><i class="fas fa-inbox"></i><p>No orders found.</p></td></tr>';
        return;
      }

      tbody.innerHTML = sampleOrders.map(order => {
        const days = Math.ceil((new Date(order.endDate) - new Date(order.startDate)) / (1000 * 60 * 60 * 24));
        return `
          <tr>
            <td><strong>${order.id}</strong></td>
            <td>${order.customer}</td>
            <td>${order.equipment}</td>
            <td>${new Date(order.orderDate).toLocaleDateString()}</td>
            <td>${days} days</td>
            <td>$${order.amount.toFixed(2)}</td>
            <td><span class="status-badge ${order.status}">${order.status}</span></td>
            <td>
              <div class="action-buttons">
                <button class="action-btn view-btn" onclick="viewOrder('${order.id}')">
                  <i class="fas fa-eye"></i> View
                </button>
                <button class="action-btn delete-btn" onclick="deleteOrder('${order.id}')">
                  <i class="fas fa-trash"></i> Delete
                </button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    function viewOrder(orderId) {
      const order = sampleOrders.find(o => o.id === orderId);
      if (!order) return;

      const days = Math.ceil((new Date(order.endDate) - new Date(order.startDate)) / (1000 * 60 * 60 * 24));
      const modalBody = document.getElementById('orderModalBody');
      modalBody.innerHTML = `
        <div class="order-details">
          <div class="detail-section">
            <h3>Order Information</h3>
            <div class="detail-row">
              <label>Order ID:</label>
              <span>${order.id}</span>
            </div>
            <div class="detail-row">
              <label>Order Date:</label>
              <span>${new Date(order.orderDate).toLocaleDateString()}</span>
            </div>
            <div class="detail-row">
              <label>Status:</label>
              <span class="status-badge ${order.status}">${order.status}</span>
            </div>
          </div>

          <div class="detail-section">
            <h3>Customer Information</h3>
            <div class="detail-row">
              <label>Name:</label>
              <span>${order.customer}</span>
            </div>
          </div>

          <div class="detail-section">
            <h3>Rental Details</h3>
            <div class="detail-row">
              <label>Equipment:</label>
              <span>${order.equipment}</span>
            </div>
            <div class="detail-row">
              <label>Start Date:</label>
              <span>${new Date(order.startDate).toLocaleDateString()}</span>
            </div>
            <div class="detail-row">
              <label>End Date:</label>
              <span>${new Date(order.endDate).toLocaleDateString()}</span>
            </div>
            <div class="detail-row">
              <label>Duration:</label>
              <span>${days} days</span>
            </div>
          </div>

          <div class="detail-section">
            <h3>Billing</h3>
            <div class="detail-row">
              <label>Total Amount:</label>
              <span class="amount">$${order.amount.toFixed(2)}</span>
            </div>
          </div>
        </div>
      `;
      document.getElementById('orderModal').classList.add('active');
    }

    function deleteOrder(orderId) {
      if (confirm('Are you sure you want to delete this order?')) {
        const index = sampleOrders.findIndex(o => o.id === orderId);
        if (index > -1) {
          sampleOrders.splice(index, 1);
          renderOrders();
          alert('Order deleted successfully');
        }
      }
    }

    // Modal controls
    document.querySelectorAll('.modal-close').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('orderModal').classList.remove('active');
      });
    });

    // Initial render
    renderOrders();
  </script>
</body>
</html>
