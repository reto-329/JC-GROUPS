<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - JC Rentals</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-login-page">
  <div class="login-split">

    <!-- Left Branding Panel -->
    <div class="login-panel">
      <div class="login-panel-inner">
        <div class="login-brand-icon"><i class="fas fa-building"></i></div>
        <h1>JC Rentals</h1>
        <p>Equipment rental management made simple. Monitor inventory, track orders, and manage your business — all in one place.</p>
        <ul class="login-features">
          <li><i class="fas fa-check-circle"></i> Real-time inventory tracking</li>
          <li><i class="fas fa-check-circle"></i> Order & booking management</li>
          <li><i class="fas fa-check-circle"></i> Customer records</li>
        </ul>
      </div>
      <div class="login-panel-orb login-panel-orb--1"></div>
      <div class="login-panel-orb login-panel-orb--2"></div>
    </div>

    <!-- Right Form Panel -->
    <div class="login-form-panel">
      <div class="login-form-inner">
        <div class="login-form-header">
          <span class="login-badge"><i class="fas fa-shield-alt"></i> Secure Area</span>
          <h2>Welcome back</h2>
          <p>Sign in to your admin account</p>
        </div>

        <% if (message) { %>
          <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i> <%= message %>
          </div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> <%= success %>
          </div>
        <% } %>

        <form method="POST" action="/admin/login" class="admin-login-form">
          <div class="form-group">
            <label for="email">Email Address</label>
            <div class="input-wrap">
              <i class="fas fa-envelope"></i>
              <input type="email" id="email" name="email" placeholder="admin@jcrentals.com" required>
            </div>
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <div class="input-wrap">
              <i class="fas fa-lock"></i>
              <input type="password" id="password" name="password" placeholder="Enter your password" required>
              <button type="button" class="pwd-toggle" data-field="password"><i class="fas fa-eye"></i></button>
            </div>
          </div>
          <button type="submit" class="admin-login-btn"><i class="fas fa-sign-in-alt"></i> Sign In</button>
        </form>

        <p class="login-note"><i class="fas fa-lock"></i> Only authorized personnel may access this panel.</p>
      </div>
    </div>

  </div>

  <script>
    document.querySelectorAll('.pwd-toggle').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        const input = document.getElementById(btn.dataset.field);
        const icon = btn.querySelector('i');
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        icon.classList.toggle('fa-eye', !isHidden);
        icon.classList.toggle('fa-eye-slash', isHidden);
      });
    });
  </script>
</body>
</html>
