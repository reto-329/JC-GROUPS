<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="JC Rentals Admin Dashboard - Business Overview">
  <title>Admin Dashboard - JC Rentals</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-dashboard-page">
  <div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <div class="admin-logo-mini">
          <i class="fas fa-leaf"></i>
        </div>
        <h2>Admin Panel</h2>
      </div>

      <nav class="admin-nav">
        <a href="/admin/dashboard" class="nav-item active">
          <i class="fas fa-chart-line"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/users" class="nav-item">
          <i class="fas fa-users"></i>
          <span>Users</span>
        </a>
        <a href="/admin/equipment" class="nav-item">
          <i class="fas fa-tools"></i>
          <span>Equipment</span>
        </a>
        <a href="/admin/orders" class="nav-item">
          <i class="fas fa-shopping-cart"></i>
          <span>Orders</span>
        </a>
      </nav>

      <div class="admin-sidebar-footer">
        <a href="/admin/logout" class="logout-btn">
          <i class="fas fa-sign-out-alt"></i>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <!-- Top Bar -->
      <div class="admin-topbar">
        <div class="topbar-left">
          <button class="admin-hamburger" id="adminHamburger" aria-label="Toggle sidebar">
            <span></span>
            <span></span>
            <span></span>
          </button>
          <h1>Dashboard</h1>
        </div>
        <div class="topbar-right">
          <div class="admin-user-info">
            <span class="admin-name"><%= adminName %></span>
            <span class="admin-role"><%= adminRole %></span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="admin-content">
        <% if (success) { %>
          <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            <%= success %>
          </div>
        <% } %>

        <!-- Welcome Section -->
        <div class="dashboard-welcome">
          <h2>Welcome back, <%= adminName %>!</h2>
          <p>Here's your business overview for today</p>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon users">
              <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
              <h3>Total Users</h3>
              <p class="stat-value"><%= stats.totalUsers || 0 %></p>
              <span class="stat-label">Active members</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon equipment">
              <i class="fas fa-tools"></i>
            </div>
            <div class="stat-content">
              <h3>Equipment</h3>
              <p class="stat-value"><%= stats.totalEquipment || 0 %></p>
              <span class="stat-label">Available items</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon orders">
              <i class="fas fa-shopping-cart"></i>
            </div>
            <div class="stat-content">
              <h3>Active Orders</h3>
              <p class="stat-value"><%= stats.activeOrders || 0 %></p>
              <span class="stat-label">Current rentals</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon revenue">
              <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="stat-content">
              <h3>Total Revenue</h3>
              <p class="stat-value">$<%= stats.totalRevenue || 0 %></p>
              <span class="stat-label">All time</span>
            </div>
          </div>
        </div>

        <!-- Quick Access Section -->
        <div class="dashboard-grid">
          <div class="dashboard-card">
            <div class="card-header">
              <h3><i class="fas fa-users"></i> User Management</h3>
              <a href="/admin/users" class="card-link">View All</a>
            </div>
            <div class="card-body">
              <p>Manage user accounts, view profiles, and handle user-related issues.</p>
              <a href="/admin/users" class="action-btn">Go to Users</a>
            </div>
          </div>

          <div class="dashboard-card">
            <div class="card-header">
              <h3><i class="fas fa-tools"></i> Equipment Inventory</h3>
              <a href="/admin/equipment" class="card-link">View All</a>
            </div>
            <div class="card-body">
              <p>View equipment inventory, manage listings, and track availability.</p>
              <a href="/admin/equipment" class="action-btn">Go to Equipment</a>
            </div>
          </div>

          <div class="dashboard-card">
            <div class="card-header">
              <h3><i class="fas fa-shopping-cart"></i> Orders</h3>
              <a href="/admin/orders" class="card-link">View All</a>
            </div>
            <div class="card-body">
              <p>Process orders, track rentals, and manage customer transactions.</p>
              <a href="/admin/orders" class="action-btn">Go to Orders</a>
            </div>
          </div>
        </div>

        <!-- Footer Stats -->
        <div class="dashboard-footer">
          <div class="footer-stat">
            <strong>Last Login:</strong> <%= lastLogin || 'First login' %>
          </div>
          <div class="footer-stat">
            <strong>Admin Role:</strong> <%= adminRole %>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    // Hamburger menu toggle
    const hamburger = document.getElementById('adminHamburger');
    const sidebar = document.querySelector('.admin-sidebar');

    if (hamburger) {
      hamburger.addEventListener('click', () => {
        sidebar.classList.toggle('active');
        hamburger.classList.toggle('active');
      });

      // Close sidebar when clicking a nav item
      document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', () => {
          sidebar.classList.remove('active');
          hamburger.classList.remove('active');
        });
      });

      // Close sidebar when clicking outside
      document.addEventListener('click', (e) => {
        if (!sidebar.contains(e.target) && !hamburger.contains(e.target)) {
          sidebar.classList.remove('active');
          hamburger.classList.remove('active');
        }
      });
    }
  </script>
</body>
</html>
