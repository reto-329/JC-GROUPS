<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=5, user-scalable=yes">
  <meta name="description" content="Manage your JC Rentals account security and change password.">
  <title>Security - JC Rentals</title>
  <link rel="icon" href="/images/Favicon.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/profile.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- Security Hero -->
  <section class="profile-hero">
    <div>
      <h1>Security Settings</h1>
      <p>Manage Your Account Security</p>
    </div>
  </section>

  <!-- Security Container -->
  <main class="profile-container">
    <div class="profile-grid">
      <!-- Sidebar Component -->
      <%- include('partials/sidebar', { activeTab: 'security', sidebarData: { title: 'Account Security', icon: 'fas fa-lock' } }) %>

      <!-- Main Content -->
      <div class="profile-content">
        <!-- Change Password Section -->
        <section class="profile-section">
          <div class="section-header">
            <h2>Change Password</h2>
          </div>

          <div id="passwordMessage"></div>

          <form id="passwordForm" class="edit-form">
            <div class="form-group">
              <label for="currentPassword">Current Password</label>
              <div class="input-wrap">
                <i class="fas fa-lock"></i>
                <input type="password" id="currentPassword" name="currentPassword" placeholder="Enter current password" required>
                <button type="button" class="pwd-toggle" data-field="currentPassword">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>

            <div class="form-group">
              <label for="newPassword">New Password</label>
              <div class="input-wrap">
                <i class="fas fa-lock"></i>
                <input type="password" id="newPassword" name="newPassword" placeholder="Min. 6 characters" required minlength="6">
                <button type="button" class="pwd-toggle" data-field="newPassword">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
              <small style="color: #999; margin-top: 0.5rem; display: block;">Must be at least 6 characters</small>
            </div>

            <div class="form-group">
              <label for="confirmPassword">Confirm New Password</label>
              <div class="input-wrap">
                <i class="fas fa-lock"></i>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Repeat new password" required minlength="6">
                <button type="button" class="pwd-toggle" data-field="confirmPassword">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn-save">Update Password</button>
            </div>
          </form>
        </section>

        <!-- Security Info Section -->
        <section class="profile-section">
          <h2>Security Information</h2>

          <div class="security-grid">
            <div class="security-item-card">
              <div class="security-icon">
                <i class="fas fa-check-circle"></i>
              </div>
              <h3>Secure Account</h3>
              <p>Your account is protected with encrypted passwords and secure sessions.</p>
            </div>
            <div class="security-item-card">
              <div class="security-icon">
                <i class="fas fa-shield-alt"></i>
              </div>
              <h3>Strong Passwords</h3>
              <p>Use a unique, strong password with at least 6 characters for better security.</p>
            </div>
            <div class="security-item-card">
              <div class="security-icon">
                <i class="fas fa-lock"></i>
              </div>
              <h3>Session Management</h3>
              <p>Your sessions are automatically managed and logged for security.</p>
            </div>
          </div>
        </section>

        <!-- Password Requirements Section -->
        <section class="profile-section">
          <h2>Password Requirements</h2>
          <ul class="security-checklist">
            <li><i class="fas fa-circle-check"></i> At least 6 characters long</li>
            <li><i class="fas fa-circle"></i> Mix uppercase and lowercase letters (recommended)</li>
            <li><i class="fas fa-circle"></i> Include numbers (recommended)</li>
            <li><i class="fas fa-circle"></i> Include special characters like !@#$% (recommended)</li>
          </ul>
        </section>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Password visibility toggle
    document.querySelectorAll('.pwd-toggle').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const fieldId = btn.dataset.field;
        const input = document.getElementById(fieldId);
        const icon = btn.querySelector('i');
        
        if (input.type === 'password') {
          input.type = 'text';
          icon.classList.remove('fa-eye');
          icon.classList.add('fa-eye-slash');
        } else {
          input.type = 'password';
          icon.classList.remove('fa-eye-slash');
          icon.classList.add('fa-eye');
        }
      });
    });

    // Handle Password Form Submission
    document.getElementById('passwordForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const messageDiv = document.getElementById('passwordMessage');
      messageDiv.innerHTML = '';

      const formData = {
        currentPassword: document.getElementById('currentPassword').value,
        newPassword: document.getElementById('newPassword').value,
        confirmPassword: document.getElementById('confirmPassword').value
      };

      // Client-side validation
      if (formData.newPassword !== formData.confirmPassword) {
        messageDiv.innerHTML = '<div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> Passwords do not match</div>';
        return;
      }

      if (formData.newPassword.length < 6) {
        messageDiv.innerHTML = '<div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> New password must be at least 6 characters</div>';
        return;
      }

      try {
        const response = await fetch('/security/change-password', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        });

        const data = await response.json();
        
        if (data.success) {
          messageDiv.innerHTML = '<div class="alert alert-success"><i class="fas fa-check-circle"></i> ' + data.message + '</div>';
          document.getElementById('passwordForm').reset();
          setTimeout(() => {
            messageDiv.innerHTML = '';
          }, 4000);
        } else {
          messageDiv.innerHTML = '<div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> ' + data.message + '</div>';
        }
      } catch (err) {
        messageDiv.innerHTML = '<div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> Error changing password</div>';
        console.error(err);
      }
    });
  </script>

</body>
</html>
