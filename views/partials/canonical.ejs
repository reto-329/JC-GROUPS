<%
  const baseUrl = process.env.SITE_URL || process.env.BASE_URL || 'https://rentals.jcgroups.ca';
  let canonicalHref = canonicalUrl || `${baseUrl}${req.path === '/' ? '' : req.path}`;
  if (canonicalHref.endsWith('/') && canonicalHref !== `${baseUrl}/`) {
    canonicalHref = canonicalHref.slice(0, -1);
  }
%>
<link rel="canonical" href="<%= canonicalHref %>" />
